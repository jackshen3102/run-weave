# Copy this file to app/.env.local for machine-specific iOS device builds.
# Do not commit app/.env.local.

# Used by pnpm app:ios:device and pnpm --filter @runweave/app ios:sync.
# Local simulator debugging is handled by pnpm app:ios:local, which overrides
# this value with the temporary local backend URL.
VITE_RUNWEAVE_API_BASE=https://your-runweave-backend.example.com
