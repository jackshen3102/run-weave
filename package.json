{
  "name": "browser-viewer-workspace",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "node ./dev.mjs",
    "dev:electron": "node ./electron-dev.mjs",
    "dist:electron:mac": "node ./scripts/electron-dist-retry.mjs --mac --arm64",
    "dist:electron:mac:local-updates": "node ./scripts/electron-dist-retry.mjs --config electron-builder.local-updates.yml --mac --arm64",
    "publish:electron:local-updates": "pnpm dist:electron:mac:local-updates && node ./scripts/publish-local-updates.mjs",
    "serve:electron:local-updates": "node ./scripts/serve-local-updates.mjs",
    "electron:local-update": "node ./scripts/electron-local-update.mjs",
    "runweave:update": "node ./scripts/runweave-update.mjs",
    "runweave:update:test-cases": "node ./scripts/runweave-update-test-cases.mjs",
    "app:dev": "node ./app-dev.mjs",
    "app:dev:ios": "APP_DEV_IOS=true node ./app-dev.mjs",
    "app:build": "pnpm --filter @runweave/app build",
    "app:ios:device": "pnpm --filter @runweave/app ios:open",
    "app:ios:local": "node ./scripts/app-ios-local.mjs",
    "app:version:bump": "node ./scripts/bump-app-version.mjs",
    "runtime:build": "node ./scripts/build-runtime-package.mjs",
    "runtime:install": "node ./scripts/install-runtime-package.mjs",
    "runtime:pack-and-install": "pnpm runtime:build && node ./scripts/install-runtime-package.mjs --latest",
    "prestart": "pnpm build",
    "start": "pnpm --filter ./backend start -- --host 127.0.0.1 --port 5001",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm run test:e2e",
    "test:e2e": "pnpm --filter ./frontend exec playwright test",
    "test:e2e:list": "pnpm --filter ./frontend exec playwright test --list",
    "cli:build": "pnpm --filter ./packages/runweave-cli build",
    "cli:version:bump": "node ./scripts/bump-runweave-cli-version.mjs",
    "cli:publish:local": "pnpm cli:version:bump && pnpm cli:build && node ./scripts/publish-runweave-cli-local.mjs",
    "toolkit:sync": "node ./scripts/sync-toolkit-plugin.mjs",
    "toolkit:sync:staged": "node ./scripts/sync-toolkit-plugin.mjs --if-staged",
    "toolkit:verify-hooks": "pnpm --filter ./electron exec tsx ../scripts/verify-toolkit-hooks.mjs",
    "perf:terminal": "node ./scripts/terminal-perf-ralph.mjs",
    "e2e": "pnpm --filter ./frontend exec playwright test",
    "quality:gate": "node ./scripts/quality-gate.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --fix",
    "*.{json,md,yaml,yml,css}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.26.0",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "node-pty"
    ]
  }
}
