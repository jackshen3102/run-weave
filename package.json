{
  "name": "runweave-workspace",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "node ./dev.mjs",
    "dev:legacy": "node ./dev.mjs",
    "dev:session": "node ./scripts/dev-session/cli.mjs start",
    "dev:session:verify": "node ./scripts/verify-dev-session.mjs",
    "dev:session:verify:beta-current": "node ./scripts/verify-dev-session.mjs --beta-current-only",
    "dev:pool": "node ./scripts/dev-session/pool-cli.mjs",
    "dev:status": "node ./scripts/dev-session/cli.mjs status",
    "dev:open": "node ./scripts/dev-session/cli.mjs open",
    "dev:stop": "node ./scripts/dev-session/cli.mjs stop",
    "dev:electron": "node ./electron-dev.mjs",
    "dist:electron:mac": "node ./scripts/electron-dist-retry.mjs --mac --arm64",
    "dist:electron:mac:local-updates": "node ./scripts/electron-dist-retry.mjs --config electron-builder.local-updates.yml --mac --arm64",
    "publish:electron:local-updates": "pnpm dist:electron:mac:local-updates && node ./scripts/publish-local-updates.mjs",
    "serve:electron:local-updates": "node ./scripts/serve-local-updates.mjs",
    "electron:local-update": "node ./scripts/electron-local-update.mjs",
    "runweave:update": "node ./scripts/runweave-update.mjs",
    "runweave:update:test-cases": "node ./scripts/runweave-update-test-cases.mjs",
    "runweave:beta:update": "node ./scripts/runweave-beta.mjs update",
    "runweave:beta:status": "node ./scripts/runweave-beta.mjs status",
    "runweave:beta:open": "node ./scripts/runweave-beta.mjs open",
    "runweave:beta:stop": "node ./scripts/runweave-beta.mjs stop",
    "runweave:beta:rollback": "node ./scripts/runweave-beta.mjs rollback",
    "runweave:beta:migrate": "node ./scripts/runweave-beta.mjs migrate",
    "runweave:beta:verify": "node ./scripts/runweave-beta.mjs verify",
    "app:dev": "node ./app-dev.mjs",
    "app:dev:ios": "APP_DEV_IOS=true node ./app-dev.mjs",
    "app:build": "pnpm --filter @runweave/app build",
    "app-server:dev": "pnpm --filter @runweave/app-server dev",
    "app-server:install": "node ./scripts/install-app-server-runtime.mjs",
    "app-server:install:test": "node ./scripts/install-app-server-runtime.mjs --home=$HOME/.runweave/app-server-test",
    "app-server:start": "pnpm --filter @runweave/cli build && node ./packages/runweave-cli/dist/index.js app-server start",
    "app-server:start:test": "RUNWEAVE_APP_SERVER_HOME=$HOME/.runweave/app-server-test pnpm --filter @runweave/cli build && RUNWEAVE_APP_SERVER_HOME=$HOME/.runweave/app-server-test node ./packages/runweave-cli/dist/index.js app-server start",
    "app-server:typecheck": "pnpm --filter @runweave/app-server typecheck",
    "app-server:verify": "node ./scripts/verify-app-server-event-center.mjs",
    "app-server:verify-cli-start": "node ./scripts/verify-app-server-cli-start.mjs",
    "app-server:verify-state-sync": "node ./scripts/verify-app-server-state-sync.mjs",
    "agent-team:verify-review-checkpoints": "pnpm --dir backend exec tsx ../scripts/verify-agent-team-review-checkpoints.mjs",
    "agent-team:verify-framework-recovery": "pnpm --dir backend exec tsx ../scripts/verify-agent-team-framework-recovery.mjs",
    "agent-team:verify-control-plane": "pnpm --dir backend exec tsx ../scripts/verify-agent-team-control-plane.mjs",
    "agent-team:verify-completion-outcome": "pnpm --dir backend exec tsx ../scripts/verify-agent-team-completion-outcome.mjs",
    "testplan:validate": "pnpm --dir backend exec tsx ../scripts/validate-test-plan.ts",
    "testplan:verify": "pnpm --dir backend exec tsx ../scripts/verify-test-plan-format.ts",
    "agent-team:verify-fixture-lifecycle": "pnpm --dir backend exec tsx ../scripts/verify-agent-team-fixture-lifecycle.mjs",
    "app-server:seed-threadref-fixture": "node ./scripts/seed-app-server-threadref-fixture.mjs",
    "app:ios:device": "pnpm --filter @runweave/app ios:open",
    "app:ios:local": "node ./scripts/app-ios-local.mjs",
    "app:version:bump": "node ./scripts/bump-app-version.mjs",
    "runtime:build": "node ./scripts/build-runtime-package.mjs",
    "runtime:install": "node ./scripts/install-runtime-package.mjs",
    "runtime:pack-and-install": "pnpm runtime:build && node ./scripts/install-runtime-package.mjs --latest",
    "prestart": "pnpm build",
    "start": "pnpm --filter ./backend start -- --host 127.0.0.1 --port 5001",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm test:e2e",
    "test:e2e": "pnpm --filter @runweave/frontend test:e2e",
    "architecture:report": "node ./scripts/architecture/check.mjs --report --output=artifacts/architecture-report.json",
    "architecture:check": "node ./scripts/architecture/check.mjs --output=artifacts/architecture-report.json",
    "architecture:verify": "node ./scripts/verify-architecture.mjs",
    "activity:verify": "pnpm --filter @runweave/backend exec tsx ../scripts/verify-activity-data-foundation.ts",
    "work-history:verify": "pnpm --filter @runweave/backend exec tsx ../scripts/verify-work-history-read-model.ts",
    "cli:build": "pnpm --filter ./packages/runweave-cli build",
    "cli:shim:local": "pnpm --filter @runweave/cli build && node ./scripts/install-runweave-bin-shim.mjs --home=$HOME/.runweave/app-server-test --cli-entry=./packages/runweave-cli/dist/index.js",
    "cli:version:bump": "node ./scripts/bump-runweave-cli-version.mjs",
    "cli:publish:local": "pnpm cli:version:bump && pnpm cli:build && node ./scripts/publish-runweave-cli-local.mjs",
    "toolkit:sync": "node ./scripts/sync-toolkit-plugin.mjs",
    "toolkit:sync:staged": "node ./scripts/sync-toolkit-plugin.mjs --if-staged",
    "toolkit:verify-hooks": "pnpm --filter ./electron exec tsx ../scripts/verify-toolkit-hooks.mjs",
    "perf:terminal": "node ./scripts/terminal-perf-ralph.mjs",
    "quality:gate": "node ./scripts/quality-gate.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --fix",
    "*.{json,md,yaml,yml,css}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.26.0",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "node-pty"
    ]
  }
}
