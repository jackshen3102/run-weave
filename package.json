{
  "name": "browser-viewer-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "node ./dev.mjs",
    "dev:headed": "BROWSER_HEADLESS=false node ./dev.mjs",
    "dev:electron": "node ./electron-dev.mjs",
    "dev:electron:headed": "BROWSER_HEADLESS=false node ./electron-dev.mjs",
    "dist:electron:mac": "node ./scripts/electron-dist-retry.mjs --mac --arm64",
    "dist:electron:mac:local-updates": "node ./scripts/electron-dist-retry.mjs --config electron-builder.local-updates.yml --mac --arm64",
    "publish:electron:local-updates": "pnpm dist:electron:mac:local-updates && node ./scripts/publish-local-updates.mjs",
    "serve:electron:local-updates": "node ./scripts/serve-local-updates.mjs",
    "prestart": "pnpm build",
    "start": "pnpm --filter ./backend start -- --host 127.0.0.1 --port 5001",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:default": "pnpm --filter ./backend test && pnpm --filter ./frontend test && pnpm --filter ./packages/shared test",
    "test:ui": "pnpm --filter ./frontend test:ui",
    "test:e2e": "pnpm --filter ./frontend e2e",
    "test:e2e:list": "pnpm --filter ./frontend exec playwright test --list",
    "test:live": "pnpm --filter ./backend test:live",
    "coverage": "pnpm --filter ./backend test:coverage && pnpm --filter ./frontend test:coverage",
    "e2e": "pnpm --filter ./frontend e2e",
    "quality:gate": "node ./scripts/quality-gate.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --fix",
    "*.{json,md,yaml,yml,css}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.26.0",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "node-pty"
    ]
  }
}
