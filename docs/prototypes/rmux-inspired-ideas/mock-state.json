    "rawSample": "{\n  \"build\": \"runweave 0.9.0\",\n  \"platform\": \"darwin-arm64\",\n  \"tmux\": { \"version\": \"3.4\", \"native\": true },\n  \"pty\": \"conpty/openpty\",\n  \"sdk_proto\": 3,\n  \"web_share\": true,\n  \"capture_snapshot\": true\n}"
  },

  "commands": {
    "target": "local:rw:vite",
    "list": [
      {
        "name": "split-window",
        "cat": "layout",
        "args": "-h | -v [-p 30] [-c cwd]",
        "desc": "在当前 pane 原生 split（tmux splitPane 真实存在）",
        "example": "split-window -h -p 40 -c ~/Code/browser-hub/runweave"
      },
      {
        "name": "select-pane",
        "cat": "layout",
        "args": "-t {target} [-L|-R|-U|-D]",
        "desc": "切换/聚焦 pane，深链到 panel target bar",
        "example": "select-pane -t local:rw:vite%2"
      },
      {
        "name": "resize-pane",
        "cat": "layout",
        "args": "-t {target} -x 80 | -y 24",
        "desc": "调整 pane 尺寸",
        "example": "resize-pane -t %2 -x 100"
      },
      {
        "name": "send-keys",
        "cat": "io",
        "args": "-t {target} 'text' [Enter]",
        "desc": "向 pane 注入按键 / 文本",
        "example": "send-keys -t %1 'pnpm typecheck' Enter"
      },
      {
        "name": "capture-pane",
        "cat": "io",
        "args": "-t {target} [-p] [-S -100]",
        "desc": "抓取滚动缓冲区文本快照，供断言/审计",
        "example": "capture-pane -t %1 -p -S -200"
      },
      {
        "name": "new-window",
        "cat": "session",
        "args": "-n name [-c cwd]",
        "desc": "在当前 session 新建 window（= 一套新 run）",
        "example": "new-window -n verify -c ~/Code/browser-hub/runweave"
      },
      {
        "name": "list-panes",
        "cat": "session",
        "args": "-t {session} [-F fmt]",
        "desc": "列出 session 下所有 pane 及其 target 句柄",
        "example": "list-panes -t rw:vite -F '#{pane_id} #{pane_active}'"
      },
      {
        "name": "web-share",
        "cat": "share",
        "args": "-t {target} [--spectator-only] [--ttl 3600]",
        "desc": "把该 pane/session 开成浏览器分享（借鉴点 1）",
        "example": "web-share -t rw:vite --spectator-only --ttl 3600"
      },
      {
        "name": "wait-for",
        "cat": "sdk",
        "args": "-t {target} --contains 'text' --timeout 8s",
        "desc": "阻塞直到 pane 出现指定文本（behavior_verify 底座）",
        "example": "wait-for -t %1 --contains 'ready in' --timeout 8s"
      }
    ]
  }
}
