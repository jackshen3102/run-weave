      },
      {
        "id": "s4",
        "op": "send_text",
        "arg": "touch frontend/src/App.tsx\\n",
        "desc": "触发一次 HMR",
        "status": "pass",
        "ms": 15,
        "detail": "已写入"
      },
      {
        "id": "s5",
        "op": "expect_visible_text",
        "matcher": "to_contain",
        "arg": "hmr update /src/App.tsx",
        "timeoutMs": 5000,
        "desc": "断言 HMR 生效",
        "status": "fail",
        "ms": 5000,
        "detail": "超时未命中：日志出现 'page reload'（整页刷新）而非 hmr update —— 疑似 React fast-refresh 边界被破坏"
      }
    ],
    "palette": [
      {
        "op": "send_text",
        "hint": "text: string —— 写入目标 pane（含 \\n 表示回车）"
      },
      {
        "op": "expect_visible_text",
        "hint": "matcher: to_contain | to_match, arg, timeoutMs —— 断言可见文本"
      },
      { "op": "capture_pane", "hint": "label: string —— 抓取当前渲染快照" },
