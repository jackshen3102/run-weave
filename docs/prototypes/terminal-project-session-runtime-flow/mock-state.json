        "name": "Terminal workspace event plane",
        "endpoint": "WS /ws/terminal-events",
        "scope": "一个 backend 的全局 Project / Session / Panel / bell / metadata 事件",
        "retention": "TerminalEventService 内存最近 500 条；after cursor 支持本进程 catchup",
        "producer": "Terminal routes、TerminalSessionManager、TerminalStateService、completion service、panel routes",
        "consumers": "Web TerminalWorkspace、App useAppSession",
        "messages": [
          "project_created / project_deleted",
          "terminal_session_created / terminal_session_deleted",
          "terminal_state_changed / terminal_session_metadata_changed",
          "terminal_bell / terminal_notification / completion",
          "terminal_panel_created / updated / deleted / focused / input_sent",
          "never carries xterm input / output / composition"
        ],
        "sources": [
          "backend/src/terminal/terminal-event-service.ts",
          "backend/src/ws/terminal-events-server.ts",
          "frontend/src/components/terminal/terminal-workspace-events.ts",
          "app/src/hooks/use-app-session.ts"
        ]
      },
      {
        "id": "agent-events",
        "tone": "amber",
        "name": "App Server agent event plane",
        "endpoint": "WS /events/stream",
        "scope": "跨进程 Agent hook / completion；scope 引用 terminal 对象",
        "retention": "App Server event store + cursor；StateProjector 持久化 ThreadRef",
        "producer": "hook / CLI / backend / electron",
        "consumers": "AppServerStateProjector、backend AppServerEventConsumer",
        "messages": [
          "agent.hook → SessionStart / UserPromptSubmit / Stop",
          "agent.completion → hook_stop / ai_process_exit",
          "derived thread.state.changed → AppServerThreadRef"
        ],
        "sources": [
          "app-server/src/event-center.ts",
          "app-server/src/state-projector.ts",
          "backend/src/app-server/event-consumer.ts"
        ]
      }
    ],
    "reactions": [
      {
        "event": "project/session created or deleted",
        "web": "调用 loadSessions()，重新 GET Project + Session",
        "app": "调用 loadOverview()，重新 GET App overview",
        "backend": "路由在 manager/store 修改完成后 record event"
      },
      {
        "event": "terminal_state_changed",
        "web": "按 terminalSessionId 更新 terminalStateBySessionId",
        "app": "按 terminalSessionId 更新 overview session 与 displayStatus",
        "backend": "TerminalStateService 写 store + record event"
      },
      {
        "event": "terminal_session_metadata_changed",
        "web": "按 terminalSessionId 更新 session cwd 与 activeCommand",
        "app": "按 terminalSessionId 更新 overview session metadata",
        "backend": "TerminalSessionManager.updateSessionMetadata 持久化后 record event"
      },
      {
        "event": "terminal_bell",
        "web": "live 事件且不是 active session 时设置 2 秒 bell marker",
        "app": "当前不展示 bell marker",
        "backend": "TerminalSessionManager.appendOutput 按 chunk 统计 BEL 并 record event"
      },
      {
        "event": "terminal panel event",
        "web": "更新 panelWorkspaceBySessionId 与 activePanelId",
        "app": "App overview 不消费 panel workspace；终端字节画面仍来自 terminal WS",
        "backend": "panel routes / tmux metadata 生成 workspace payload"
      },
      {
        "event": "completion",
        "web": "设置 completion marker；Electron live delivery 播放 bell",
        "app": "首页状态主要依赖 terminal_state_changed，不用 completion marker",
        "backend": "completion service 同时落入 TerminalEventService"
      },
      {
        "event": "App Server agent.hook / completion",
        "web": "不直接连接 App Server",
        "app": "不直接连接 App Server",
        "backend": "过滤 ownership 后更新 TerminalState，再广播 terminal_state_changed"
      }
    ]
  },
  "objects": {
    "relations": [
      {
        "from": "Connection / apiBase",
        "cardinality": "1 → 1",
        "to": "Backend instance",
        "meaning": "客户端本地选择；决定所有 HTTP/WS 请求发往哪里"
      },
      {
        "from": "Backend instance",
        "cardinality": "1 → N",
        "to": "Project",
        "meaning": "TerminalSessionManager + TerminalSessionStore 持有"
      },
      {
        "from": "Project",
        "cardinality": "1 → N",
        "to": "Terminal Session",
        "meaning": "Session.projectId 是归属键；Session.cwd 可独立变化"
      },
      {
        "from": "Terminal Session",
        "cardinality": "1 → 1",
        "to": "Runtime entry",
        "meaning": "TerminalRuntimeRegistry 以 terminalSessionId 为 key"
      },
      {
        "from": "tmux Terminal Session",
        "cardinality": "1 → N",
        "to": "Panel / tmux pane",
        "meaning": "Panel.terminalSessionId + tmuxPaneId；Workspace 记录 activePanelId"
      },
      {
        "from": "Terminal Session",
        "cardinality": "1 → 0..N",
        "to": "xterm / WS client",
        "meaning": "只有已挂载 xterm 的 Web cache、App 或其它浏览器会连接该 session"
      },
      {
        "from": "Web xterm composition",
        "cardinality": "1 → 0..1",
        "to": "TerminalImeCommit",
        "meaning": "预编辑为 0 个 terminal frame；每轮候选提交最多形成 1 个 terminal input frame"
      },
      {
        "from": "Agent ThreadRef",
        "cardinality": "N → 0..1",
        "to": "Project / Session / Panel",
        "meaning": "App Server scope 引用；不是终端对象的父级"
      }
    ],
    "identity": [
      {
        "object": "Connection",
        "key": "connectionId / apiBase",
        "owner": "客户端本地 store",
        "persisted": "是，客户端本地",
        "endsWhen": "用户删除连接或切换 active connection",
        "source": "frontend/src/features/connection/use-connections.ts · app/src/store/use-app-connection-store.ts"
      },
      {
        "object": "Project",
        "key": "projectId",
        "owner": "TerminalSessionManager",
        "persisted": "TerminalSessionStore",
        "endsWhen": "DELETE project；子 session 一并销毁；至少会补一个 Default Project",
        "source": "backend/src/terminal/manager.ts"
      },
      {
        "object": "Terminal Session",
        "key": "terminalSessionId",
        "owner": "TerminalSessionManager",
        "persisted": "TerminalSessionStore",
        "endsWhen": "DELETE session；process exit 只把 status 标为 exited，不删除记录",
        "source": "backend/src/terminal/manager.ts"
      },
      {
        "object": "Panel",
        "key": "panelId + tmuxPaneId",
        "owner": "TerminalSessionManager / tmux",
        "persisted": "TerminalSessionStore",
        "endsWhen": "kill/remove pane 或删除 session",
        "source": "backend/src/terminal/manager-records.ts"
      },
      {
        "object": "xterm Terminal",
        "key": "React mount + terminalSessionId",
        "owner": "TerminalSurface / TerminalRenderer",
        "persisted": "否",
        "endsWhen": "组件 unmount；surface cache 内 inactive 组件仍保持 mounted",
        "source": "frontend/src/components/terminal/use-terminal-emulator.ts · packages/terminal-renderer/src/TerminalRenderer.tsx"
      },
      {
        "object": "TerminalImeCommit",
        "key": "当前 composition",
        "owner": "Web TerminalSurface",
        "persisted": "否，React ref",
        "endsWhen": "新的 compositionstart、普通键盘输入、paste 或 250 ms 提交窗口结束",
        "source": "frontend/src/components/terminal/terminal-surface-utils.ts · frontend/src/components/terminal/use-terminal-emulator.ts"
      },
      {
        "object": "Runtime entry",
        "key": "terminalSessionId",
        "owner": "TerminalRuntimeRegistry",
        "persisted": "否；runtime metadata 在 session 中持久化",
        "endsWhen": "disposeRuntime；tmux attach runtime 与 tmux session 生命周期分离",
        "source": "backend/src/terminal/runtime-registry.ts"
      },
      {
        "object": "ThreadRef",
        "key": "threadId",
        "owner": "AppServerStateStore",
        "persisted": "App Server state store",
        "endsWhen": "由后续 Agent event 持续更新；与 terminal delete 没有直接级联代码",
        "source": "packages/shared/src/app-server-events.ts · app-server/src/state-store.ts"
      }
    ],
    "counts": [
      {
        "metric": "Web cached TerminalSurface",
        "value": "≤ 10",
        "unit": "跨当前 backend 的最近 session",
        "contains": "每个含 xterm + terminal WS；inactive surface 屏幕外挂载",
        "source": "frontend/src/features/terminal/surface-cache.ts"
      },
      {
        "metric": "Web global terminal-events connection",
        "value": "1",
        "unit": "每个 Terminal Workspace / backend 连接",
        "contains": "统一接收 Project、Session、Panel、state、completion、bell 与 metadata",
        "source": "frontend/src/features/terminal/use-terminal-events-connection.ts"
      },
      {
        "metric": "App live TerminalRenderer",
        "value": "1",
        "unit": "当前 terminal detail route",
        "contains": "一个 xterm + 一个 terminal WS；history modal 是独立只读 renderer",
        "source": "app/src/pages/AppTerminalPage.tsx"
      },
      {
        "metric": "Backend runtime entry",
        "value": "≤ 1",
        "unit": "每个 terminalSessionId",
        "contains": "一个 PtyRuntime、attached client set、subscribers、64 KiB buffered output",
        "source": "backend/src/terminal/runtime-registry.ts"
      },
      {
        "metric": "TerminalEvent backlog",
        "value": "500",
        "unit": "每个 backend 进程",
        "contains": "内存事件；after cursor 只覆盖当前服务保留窗口",
        "source": "backend/src/terminal/terminal-event-service.ts"
      }
    ]
  },
  "interfaces": [
    {
      "type": "REST",
      "method": "GET",
      "path": "/api/terminal/project",
      "purpose": "列出 backend Project 主数据",
      "payload": "TerminalProjectListItem[]",
      "consumers": "Web TerminalWorkspace",
      "source": "backend/src/routes/terminal-project-routes.ts"
    },
    {
      "type": "REST",
      "method": "GET",
      "path": "/api/terminal/session",
      "purpose": "列出全部 Terminal Session 与折叠状态",
      "payload": "TerminalSessionListItem[]",
      "consumers": "Web TerminalWorkspace",
      "source": "backend/src/routes/terminal.ts"
    },
    {
      "type": "REST",
      "method": "GET",
      "path": "/api/app/home/overview",
      "purpose": "App-only Project + Session 聚合列表",
      "payload": "AppHomeOverviewResponse",
      "consumers": "App useAppSession",
      "source": "backend/src/routes/app-home-overview.ts"
    },
    {
      "type": "REST",
      "method": "POST",
      "path": "/api/terminal/project",
      "purpose": "创建 Project",
      "payload": "name, path? → TerminalProjectListItem",
      "consumers": "Web / App",
      "source": "backend/src/routes/terminal-project-routes.ts"
    },
    {
      "type": "REST",
      "method": "POST",
      "path": "/api/terminal/session",
      "purpose": "创建 Session 并初始化 runtime / default panel",
      "payload": "projectId?, cwd?, inherit?, runtimePreference? → terminalSessionId",
      "consumers": "Web / App / CLI",
      "source": "backend/src/routes/terminal.ts"
    },
    {
      "type": "REST",
      "method": "GET",
      "path": "/api/terminal/session/:id",
