    },
    {
      "type": "REST",
      "method": "POST",
      "path": "/api/terminal/session/:id/input",
      "purpose": "按 raw/line/slash/paste/replace/copy-mode 分发输入",
      "payload": "SendTerminalInputRequest → accepted operation",
      "consumers": "Web floating composer / App composer / tools",
      "source": "backend/src/routes/terminal-input-dispatcher.ts"
    },
    {
      "type": "REST",
      "method": "POST",
      "path": "/api/terminal/session/:id/interrupt",
      "purpose": "发送 escape interrupt 并更新 Agent state",
      "payload": "panel selector? → SendTerminalInterruptResponse",
      "consumers": "App Stop / Web controls / CLI",
      "source": "backend/src/routes/terminal.ts"
    },
    {
      "type": "REST",
      "method": "GET",
      "path": "/api/terminal/session/:id/state",
      "purpose": "读取 TerminalState 权威视图",
      "payload": "{ terminalState }",
      "consumers": "App detail / control plane",
      "source": "backend/src/routes/terminal-state.ts"
    },
    {
      "type": "REST",
      "method": "GET/POST/PATCH/DELETE",
      "path": "/api/terminal/session/:id/panels[...]",
      "purpose": "列出、拆分、更新、删除、resize、input、interrupt Panel",
      "payload": "TerminalPanelWorkspace / panel operation",
      "consumers": "Web panel split / Agent Team / CLI",
      "source": "backend/src/routes/terminal-panel-routes.ts"
    },
    {
      "type": "REST",
      "method": "POST",
      "path": "/api/terminal/session/:id/ws-ticket",
      "purpose": "签发绑定 terminalSessionId 的短期 terminal WS ticket",
      "payload": "{ ticket }",
      "consumers": "Web / App terminal connection",
      "source": "backend/src/routes/terminal-ticket-routes.ts"
    },
    {
      "type": "REST",
      "method": "POST",
      "path": "/api/terminal/events/ws-ticket",
      "purpose": "签发 terminal-events WS ticket + baselineEventId",
      "payload": "{ ticket, baselineEventId }",
      "consumers": "Web workspace / App session",
      "source": "backend/src/routes/terminal-ticket-routes.ts"
    },
    {
      "type": "WebSocket",
      "method": "WS",
      "path": "/ws/terminal?terminalSessionId=:id&token=:ticket",
      "purpose": "xterm 已提交 input、resize、snapshot、output 与连接级 status；IME preedit 不进入协议，metadata 帧仅作兼容",
      "payload": "committed TerminalClientMessage ↔ TerminalServerMessage",
      "consumers": "TerminalSurface / App terminal",
      "source": "backend/src/ws/terminal-server.ts"
    },
    {
      "type": "WebSocket",
      "method": "WS",
      "path": "/ws/terminal-events?after=:cursor&token=:ticket",
      "purpose": "Project / Session / Panel / state / completion / bell / metadata 的全局 catchup + live 广播；不承载 terminal input/output",
      "payload": "TerminalEventServerMessage",
      "consumers": "Web workspace / App session",
      "source": "backend/src/ws/terminal-events-server.ts"
    },
    {
      "type": "Internal",
      "method": "POST",
      "path": "App Server /events",
      "purpose": "记录 agent.hook / agent.completion 等跨进程事件",
      "payload": "CreateAppServerEventRequest",
      "consumers": "AppServerEventCenter",
      "source": "app-server/src/http-server.ts"
    },
    {
      "type": "Internal",
      "method": "WS",
      "path": "App Server /events/stream?kind=agent.hook&kind=agent.completion",
      "purpose": "backend 以持久 cursor 消费属于自己的 Agent 事件",
      "payload": "AppServerEventStreamMessage",
      "consumers": "AppServerEventConsumer",
      "source": "backend/src/app-server/event-consumer.ts"
    },
    {
      "type": "Internal",
      "method": "in-process",
      "path": "TerminalEventService.record / subscribe",
      "purpose": "把 route/session manager/state/completion/panel 变化转换成 workspace event",
      "payload": "TerminalEventEnvelope",
      "consumers": "terminal-events WS / Agent Team service",
      "source": "backend/src/terminal/terminal-event-service.ts"
    },
    {
      "type": "Internal",
      "method": "in-process",
      "path": "TerminalRuntimeRegistry",
      "purpose": "按 session 共享 runtime、client 集合与 output subscribers",
      "payload": "PtyRuntime / RuntimeSubscriber",
      "consumers": "terminal WS / REST input / recorder",
      "source": "backend/src/terminal/runtime-registry.ts"
    }
  ]
}
