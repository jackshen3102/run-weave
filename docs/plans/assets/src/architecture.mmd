flowchart TB
  user([用户])
  cfg["② 配置弹窗 / Side Card Tab<br/>定义角色 · 选终端 · 选主Agent · 写提示语"]
  pkg[("① 任务包 JSON<br/>.runweave/runs/&lt;runId&gt;.json")]

  subgraph MAIN["③ 主 Agent = 常驻终端 agent (决策大脑)"]
    direction TB
    brain["收启动提示语 → 拆目标 → 用 rw 派 worker<br/>→ 结果直发回灌 → 判断继续/收尾/需人工<br/>→ 更新任务包状态 → 继续 (保留全程上下文)"]
  end

  subgraph WK["④ Worker 池 (带角色, 每个=一个终端)"]
    direction LR
    w1["coder"]
    w2["reviewer"]
    w3["fixer"]
    w4["tester"]
  end

  router["⑥ 结果路由器 (薄 Node, 在 backend 内)<br/>收 hook → 匹配 goalId → 读 outbox<br/>→ rw send 直发主 Agent (不判断忙闲)"]
  human["⑦ 人机接口<br/>need_human → 暂停 + 通知<br/>人给继续提示 → 注入主Agent"]

  user --> cfg --> pkg
  pkg -->|启动| brain
  brain -->|"rw run / send (亲自下发)"| WK
  WK -->|"完成: 写 outbox + 触发 hook"| router
  router -->|"⑤ 结果直发主 Agent 终端<br/>(立即发, 终端自排队)"| brain
  brain <-->|读/写状态| pkg
  brain -->|判定需人工| human
  human -->|继续提示| brain

  classDef brainBox fill:#1e3a5f,stroke:#4a90d9,color:#fff;
  classDef pkgBox fill:#3d2f5f,stroke:#9b7fd9,color:#fff;
  classDef routerBox fill:#1f4f3d,stroke:#4ad99b,color:#fff;
  classDef humanBox fill:#5f3d2f,stroke:#d99b4a,color:#fff;
  class brain brainBox;
  class pkg pkgBox;
  class router routerBox;
  class human humanBox;
