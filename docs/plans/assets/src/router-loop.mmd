flowchart TB
  start([worker 完成])
  sub["订阅 /ws/terminal-events<br/>收 worker completion 事件"]
  readout["读其 outbox/&lt;sessionId&gt;.json"]
  match["按 sessionId/goalId 匹配任务包目标"]
  build["拼成人类可读 query"]
  send["rw send 直发主 Agent 终端<br/>(不判断它忙闲, 立即发)"]
  queue["输入排进主 Agent 队列<br/>→ 回合结束后依次消费决策"]

  note["完全确定性: 匹配 + 读结果 + 直发<br/>排队交给终端运行时, 路由器不维护忙闲/pending<br/>智能决策全在主 Agent 终端"]

  start --> sub --> readout --> match --> build --> send --> queue
  queue --> done([继续监听])

  classDef accent fill:#1f4f3d,stroke:#4ad99b,color:#fff;
  classDef warn fill:#5f3d2f,stroke:#d99b4a,color:#fff;
  class send accent;
  class note warn;
